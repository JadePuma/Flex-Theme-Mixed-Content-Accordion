{% comment %}
  Mixed Content Accordion for product and brand pages
  Code created by JadePuma
  Tutorial Can be found here : https://jadepuma.com/blogs/shopify-tutorials/add-a-content-accordion-section-in-the-flex-theme?_pos=1&_sid=3fb17e635&_ss=r
  Last editted - 02March26
{% endcomment %}


{%- assign id = section.id -%}
{%- assign padding_top = section.settings.padding_top -%}
{%- assign padding_bottom = section.settings.padding_bottom -%}
{%- assign width = section.settings.width -%}
{%- assign accordion_icon_color = section.settings.accordion_icon_color -%}

{%- capture icon_set -%}
  {% if section.settings.toggle_icon_style == 'carets' %}
    {% render 'icon', name: 'down-caret', icon_class: 'icon--rotate' %}
  {% else %}
    {% render 'icon', name: 'plus', icon_class: 'icon--active' %}
    {% render 'icon', name: 'minus' %}
  {% endif %}
{%- endcapture -%}

{%- comment -%}
  Detect metaobject FAQ group (optionally overridden by section setting)
{%- endcomment -%}
{%- assign faq_group = blank -%}

{%- if section.settings.enable_metaobject_faqs -%}

  {%- if section.settings.faq_group_override != blank -%}
    {%- assign faq_group = section.settings.faq_group_override -%}
  {%- elsif article and article.metafields.custom.faq_group.value != blank -%}
    {%- assign faq_group = article.metafields.custom.faq_group.value -%}
  {%- elsif product and product.metafields.custom.faq_group.value != blank -%}
    {%- assign faq_group = product.metafields.custom.faq_group.value -%}
  {%- elsif page and page.metafields.custom.faq_group.value != blank -%}
    {%- assign faq_group = page.metafields.custom.faq_group.value -%}
  {%- elsif collection and collection.metafields.custom.faq_group.value != blank -%}
    {%- assign faq_group = collection.metafields.custom.faq_group.value -%}
  {%- endif -%}

{%- endif -%}

{%- assign has_metaobject_faqs = false -%}
{%- if faq_group != blank and faq_group.items.value != blank and faq_group.items.value.size > 0 -%}
  {%- assign has_metaobject_faqs = true -%}
{%- endif -%}

{%- assign should_render_section = false -%}
{%- if section.blocks.size > 0 or has_metaobject_faqs -%}
  {%- assign should_render_section = true -%}
{%- endif -%}

{% if should_render_section %}


  {%- comment -%}
    FAQ structured data
    Priority: Metaobject FAQs (custom.faq_group) → else FAQ blocks
  {%- endcomment -%}

  {%- if has_metaobject_faqs -%}
    <script type="application/ld+json">
    {
      "@context": "https://schema.org",
      "@type": "FAQPage",
      "mainEntity": [
        {%- for item in faq_group.items.value -%}
          {
            "@type": "Question",
            "name": {{ item.question | strip_html | strip | json }},
            "acceptedAnswer": {
              "@type": "Answer",
              "text": {{ item.answer | metafield_tag | strip_html | strip_newlines | strip | json }}
            }
          }{%- unless forloop.last -%},{%- endunless -%}
        {%- endfor -%}
      ]
    }
    </script>

  {%- else -%}

    {%- assign has_faq_schema = false -%}
    {%- for block in section.blocks -%}
      {%- if block.type == 'faq'
        and block.settings.title != blank
        and block.settings.answer != blank
      -%}
        {%- assign has_faq_schema = true -%}
        {%- break -%}
      {%- endif -%}
    {%- endfor -%}

    {%- if has_faq_schema -%}
      <script type="application/ld+json">
      {
        "@context": "https://schema.org",
        "@type": "FAQPage",
        "mainEntity": [
          {%- assign first = true -%}
          {%- for block in section.blocks -%}
            {%- if block.type == 'faq'
              and block.settings.title != blank
              and block.settings.answer != blank
            -%}
              {%- unless first -%},{%- endunless -%}
              {
                "@type": "Question",
                "name": {{ block.settings.title | strip_html | strip | json }},
                "acceptedAnswer": {
                  "@type": "Answer",
                  "text": {{ block.settings.answer | strip_html | strip_newlines | strip | json }}
                }
              }
              {%- assign first = false -%}
            {%- endif -%}
          {%- endfor -%}
        ]
      }
      </script>
    {%- endif -%}

  {%- endif -%}


  {% if template contains 'page' %}
    {% assign brand_page = page %}
  {% elsif template contains 'product' %}
    {% assign page_handle = product.vendor | handleize %}

    {% assign brand_page = pages[page_handle] %}
  {% endif %}

  {% style %}
    #shopify-section-{{ id }} {
      padding-top: {{ padding_top }}px;
      padding-bottom: {{ padding_bottom }}px;
      {% if section.settings.width == 'wide' %}
        width: 100%;
      {% endif %}
    }





    .multiple_accordion_container-{{ id }}{
        padding: 0px 10px;
        margin:20px auto;
    }



    .multiple_accordion_title-{{ id }}{
      display:grid;
      grid-template-columns: 42px auto;
      padding: 10px 0px 10px;
      color:{{section.settings.tab_heading_color}};
      border-bottom:1px solid {{settings.border_color}};
      font-size: 1.2rem;
      padding: 20px 0;

    }

    .multiple_accordion_content-{{ id }}{
      text-align:left;
      display:none;
      padding:20px 30px;
      background-color:{{ section.settings.accordion_inner_background }};
    }

    .accordian_content_heading-{{ id }}{
        margin-top:30px;
    }

    .multiple_accordion_title-{{ id }}:not(.active){
      background-color:{{ section.settings.tab_non_active_background_color }};
    }
    
    .multiple_accordion_title-{{ id }}:hover{
      cursor:pointer;
      background-color:{{section.settings.tab_hover_color}};
      color:{{ section.settings.tab_hover_text_color }};
    }

    

    .multiple_accordion_title-{{ id }}.active{
      background-color:{{ section.settings.tab_active_background_color }};
      color:{{ section.settings.tab_hover_text_color }};
    }




    @media only screen and (max-width: 600px) {
    .multiple_accordion_content-{{ id }}{
      text-align:left;
      display:none;
      padding:20px 10px;


    }
 
    }

    /* === JP icon style toggle (Flex-style icons) === */
    .multiple_accordion_title-{{ id }}.accordion-style--plus .icon { display:none; }
    .multiple_accordion_title-{{ id }}.accordion-style--plus .icon--active { display:inline-block; }

    /* when open, show minus instead of plus */
    .multiple_accordion_title-{{ id }}.accordion-style--plus.active .icon--active { display:none; }
    .multiple_accordion_title-{{ id }}.accordion-style--plus.active .icon:not(.icon--active) { display:inline-block; }

    /* caret rotate */
    .multiple_accordion_title-{{ id }}.accordion-style--carets .icon--rotate{
      transition: transform .2s ease;
      transform: translateY(3px) rotate(0deg);
    }
    .multiple_accordion_title-{{ id }}.accordion-style--carets.active .icon--rotate{
      transform: translateY(3px) rotate(180deg);
    }


    .jp-accordion-icon-slot{
      margin:0 10px;
      display:flex;
      justify-content:center;
    }
    .jp-accordion-icon-slot .icon{
      transform: translateY(3px);
    }


    .jp-accordion-icon-slot{
      color: {{ accordion_icon_color }};
    }


  {% endstyle %}

  <div id="about-the-brand-position"></div>
  <section
    class="
      section content {{ section.settings.css_class }}
      is-width-{{ width }}
    "
  >
    <div class="multiple_accordion_container-{{ id }}" style="margin-bottom:-20px !important;">
      
      {%- if section.settings.title != blank -%}
        {% render 'heading',
          title: section.settings.title,
          heading_tag: 'h2',
          context: 'faq',
          text_alignment: 'left'
        %}
        {%- endif -%}

        {%- if has_metaobject_faqs -%}

          {%- if has_metaobject_faqs and faq_group.heading != blank -%}
            <h2 class="title faq-title" style="margin-bottom:1rem;">{{ faq_group.heading | escape }}</h2>
          {%- endif -%}


          {%- for item in faq_group.items.value -%}
            <div class="multiple_accordion_item item-{{ id }} {% if forloop.first %} firstAccordionItem {% endif %}">
              <div class="multiple_accordion_title-{{ id }} accordion-style--{{ section.settings.toggle_icon_style }}">
                <div class="jp-accordion-icon-slot">
                  {{ icon_set }}
                </div>
                {{ item.question | strip_html }}
              </div>

              <div class="multiple_accordion_content-{{ id }}">
                {{ item.answer | metafield_tag }}
              </div>
            </div>
          {%- endfor -%}
        {%- endif -%}

      



      {% for block in section.blocks %}


        {% if block.type == 'heading' %}

            {% if block.settings.title != blank %}
              <h2 class="title faq-title" style="margin-bottom:1rem;">{{ block.settings.title }}</h2>
            {% endif %}



        {% elsif block.type == 'shipping' %}
          <div class="multiple_accordion_item item-{{ id }} {% if forloop.index == 1 %} firstAccordionItem {% endif %}" id="{{block.settings.custom_id}}">
            <div class="multiple_accordion_title-{{ id }} accordion-style--{{ section.settings.toggle_icon_style }}">

          <div class="jp-accordion-icon-slot">
            {{ icon_set }}
          </div>
            {% if block.settings.icon_label != blank %}

              {%- assign icon = block.settings.icon_label | downcase -%}

             <span>
             <span class="accordion-icon">
             {%
                render 'icon',
                name: icon
                %}
              </span>

              {% style %}

              .accordion-icon .icon{
                transform: translateY(3px) scale(1.2);
                margin-left:10px;
                margin-right:10px;
                
                
              }

              {% endstyle %}


              {% endif %}

                {% if block.settings.title != blank %}
                  {{ block.settings.title | strip_html }}
                {% else %}
                  Shipping
                {% endif %}
            </span>

            </div>

            <div class="multiple_accordion_content-{{ id }}">
              {{ shop.shipping_policy }}
            </div>
          </div>

        

        {% elsif block.type == 'returns' %}
          <div class="multiple_accordion_item item-{{ id }} {% if forloop.index == 1 %} firstAccordionItem {% endif %}" id="{{block.settings.custom_id}}">
            <div class="multiple_accordion_title-{{ id }} accordion-style--{{ section.settings.toggle_icon_style }}">

            <div class="jp-accordion-icon-slot">
              {{ icon_set }}
            </div>

            {% if block.settings.icon_label != blank %}

              {%- assign icon = block.settings.icon_label | downcase -%}

             <span>
             <span class="accordion-icon">
             {%
                render 'icon',
                name: icon
                %}
              </span>

              {% style %}

              .accordion-icon .icon{
                transform: translateY(3px) scale(1.2);
                margin-left:10px;
                margin-right:10px;
                
                
              }

              {% endstyle %}


              {% endif %}
                
                {% if block.settings.title != blank %}
                  {{ block.settings.title | strip_html }}
                {% else %}
                  Refund Policy
                {% endif %}

            </span>

            </div>

            <div class="multiple_accordion_content-{{ id }}">
              {{ shop.refund_policy }}
            </div>
          </div>

        {% elsif block.type == 'page' %}
          {% assign page = block.settings.page %}
            <div class="multiple_accordion_item item-{{ id }} {% if forloop.index == 1 %} firstAccordionItem {% endif %}" id="{{block.settings.custom_id}}">
            <div class="multiple_accordion_title-{{ id }} accordion-style--{{ section.settings.toggle_icon_style }}">

            <div class="jp-accordion-icon-slot">
              {{ icon_set }}
            </div>


            {% if block.settings.icon_label != blank %}

              {%- assign icon = block.settings.icon_label | downcase -%}

             <span>
             <span class="accordion-icon">
             {%
                render 'icon',
                name: icon
                %}
              </span>

              {% style %}

              .accordion-icon .icon{
                transform: translateY(3px) scale(1.2);
                margin-left:10px;
                margin-right:10px;
                
                
              }

              {% endstyle %}


              {% endif %}
                {% if block.settings.heading == "" %}
                  {{ page.title | strip_html }}
                {% else %}
                  {{ block.settings.heading }}
               {% endif %}

            </span>

            </div>

            <div class="multiple_accordion_content-{{ id }}">
              {{ page.content }}
            </div>
          </div>

        {% elsif block.type == 'content' %}

          {% unless block.settings.hide_if_no_description  and  block.settings.content_text == blank %}


          <div class="multiple_accordion_item item-{{ id }} {% if forloop.index == 1 %} firstAccordionItem {% endif %}" id="{{block.settings.custom_id}}" >
            <div class="multiple_accordion_title-{{ id }} accordion-style--{{ section.settings.toggle_icon_style }}">

            <div class="jp-accordion-icon-slot">
              {{ icon_set }}
            </div>


            {% if block.settings.icon_label != blank %}

              {%- assign icon = block.settings.icon_label | downcase -%}

             <span>
             <span class="accordion-icon">
             {%
                render 'icon',
                name: icon
                %}
              </span>

              {% style %}

              .accordion-icon .icon{
                transform: translateY(3px) scale(1.2);
                margin-left:10px;
                margin-right:10px;
              }

              {% endstyle %}


              {% endif %}


              {{ block.settings.title | strip_html }}
            </span>
            
            </div>

            <div class="multiple_accordion_content-{{ id }}">
              {% unless block.settings.content_heading == blank %}
                <h2 class="accordian_content_heading">{{ block.settings.content_heading }}</h2>
              {% endunless %}
  

              {% if block.settings.image_1 != blank %}
              <div class="accordion_section_image-container--{{block.id}}">
              <img  class="accordion_section_image--{{block.id}}" src="{{block.settings.image_1 | img_url: 'master'}}" alt="{{ block.settings.image_1.alt }}">
              </div>


              {% style %}

                .accordion_section_image--{{block.id}}{
                  width:100%;
                  max-width: {{block.settings.image_max_width}}px;
                  margin:10px 0;
                }

                .accordion_section_image-container--{{block.id}}{
                  display:flex;
                  {% if block.settings.image_alignment == "center" %}
                  justify-content:center;
                  {% endif %}
                }

                

              {% endstyle %}


              {% endif %}


              {{ block.settings.content_text }}

              {% if block.settings.youtube_id != blank %}
                <br>
                <div>
                  <style>
                    .embed-container { position: relative; padding-bottom: 56.25%; height: 0; overflow: hidden; max-width: 100%; }
                    .embed-container iframe, .embed-container object, .embed-container embed { position: absolute; top: 0; left: 0; width: 100%; height: 100%; }
                  </style>
                  <div class="embed-container">
                    <iframe
                      src="https://www.youtube.com/embed/{{ block.settings.youtube_id }}"
                      frameborder="0"
                      allowfullscreen
                    ></iframe>
                  </div>
                </div>
                <br>
              {% endif %}

              {% if block.settings.youtube_id_2 != blank %}
                <br>
                <div>
                  <style>
                    .embed-container { position: relative; padding-bottom: 56.25%; height: 0; overflow: hidden; max-width: 100%; }
                    .embed-container iframe, .embed-container object, .embed-container embed { position: absolute; top: 0; left: 0; width: 100%; height: 100%; }
                  </style>
                  <div class="embed-container">
                    <iframe
                      src="https://www.youtube.com/embed/{{ block.settings.youtube_id_2 }}"
                      frameborder="0"
                      allowfullscreen
                    ></iframe>
                  </div>
                </div>
                <br>
              {% endif %}
              {{ block.settings.liquid_code }}
            </div>
          
          </div>

          {% endunless %}

        {% elsif block.type == 'faq' %}

            <div class="multiple_accordion_item item-{{ id }} {% if forloop.index == 1 %} firstAccordionItem {% endif %}" id="{{ block.settings.custom_id }}">
              <div class="multiple_accordion_title-{{ id }} accordion-style--{{ section.settings.toggle_icon_style }}">

                <div class="jp-accordion-icon-slot">
                  {{ icon_set }}
                </div>

                {% if block.settings.icon_label != blank %}
                  {%- assign icon = block.settings.icon_label | downcase -%}

                  <span>
                    <span class="accordion-icon">
                      {% render 'icon', name: icon %}
                    </span>

                    {% style %}
                      .accordion-icon .icon{
                        transform: translateY(3px) scale(1.2);
                        margin-left:10px;
                        margin-right:10px;
                      }
                    {% endstyle %}
                {% endif %}

                {{ block.settings.title | strip_html }}
                </span>

              </div>

              <div class="multiple_accordion_content-{{ id }}">
                {{ block.settings.answer }}
              </div>
            </div>


          {% endif %}

      {% endfor %}
    </div>
  </section>

  <script src="https://ajax.googleapis.com/ajax/libs/jquery/3.6.0/jquery.min.js"></script>



<script>
  jQuery(function($) {
    var $section = $('#shopify-section-{{ id }}');

    // Click handler: only titles toggle the accordion
    $section.on('click', '.multiple_accordion_title-{{ id }}', function(e) {
      e.preventDefault();

      var $title        = $(this);
      var $item         = $title.closest('.item-{{ id }}');
      var $content      = $item.children('.multiple_accordion_content-{{ id }}');
      var isOpen        = $content.hasClass('open');

      // If already open → close it
      if (isOpen) {
        $content.removeClass('open').slideUp(300);
        $title.removeClass('active');
        return;
      }

      // If auto_close enabled, close all others first
      {% if section.settings.auto_close %}
        var $allItems = $section.find('.item-{{ id }}');

        $allItems.find('.multiple_accordion_content-{{ id }}')
          .removeClass('open')
          .slideUp(300);

        $allItems.find('.multiple_accordion_title-{{ id }}')
          .removeClass('active');

      {% endif %}

      // Open this one
      $content.addClass('open').slideDown(300);
      $title.addClass('active');
    });

    // Auto-open first visible accordion item on page load (if enabled)
    {% if section.settings.open_first_accordion_on_page_load %}
      var $firstTitle = $section
        .find('.item-{{ id }}:visible .multiple_accordion_title-{{ id }}')
        .first();

      if ($firstTitle.length) {
        $firstTitle.trigger('click');
      }
    {% endif %}
  });
</script>

  
{% endif %}

{% schema %}
  {
  "name": "JP Content Accordion",
  "settings": [
    {
      "type": "header",
      "content": "Settings"
    },
    {
      "type": "text",
      "id": "title",
      "label": "Heading",
      "info": "If this field left blank, it will use the brand page metafield 'Accordion heading'"
    },
    {
      "type": "checkbox",
      "id": "enable_metaobject_faqs",
      "label": "Show metaobject FAQs if available",
      "default": true
    },
    {
      "type": "header",
      "content": "Layout"
    },
    {
      "type": "select",
      "id": "toggle_icon_style",
      "label": "Accordion icon style",
      "default": "plus",
      "options": [
        { "value": "plus", "label": "Plus / minus" },
        { "value": "carets", "label": "Caret (rotates)" }
      ]
    },
    {
    "type": "checkbox",
    "id": "auto_close",
    "label": "Open 1 at a time",
    "default": false
    },
    {
    "type": "checkbox",
    "id": "open_first_accordion_on_page_load",
    "label": "Auto-open first accordion",
    "default": false
    },
    {
      "type": "select",
      "id": "width",
      "label": "Width",
      "default": "standard",
      "options": [
        {
          "value": "standard",
          "label": "Standard"
        },
        {
          "value": "wide",
          "label": "Wide"
        }
      ]
    },
    {
      "type": "range",
      "id": "padding_top",
      "label": "Top spacing",
      "min": 0,
      "max": 80,
      "default": 56,
      "unit": "px"
    },
    {
      "type": "range",
      "id": "padding_bottom",
      "label": "Bottom spacing",
      "min": 0,
      "max": 80,
      "default": 56,
      "unit": "px"
    },
    {
      "type": "header",
      "content": "Accordion Tab Colors"
    },
    {
      "type": "color",
      "id": "tab_active_background_color",
      "label": "Active tab background color"
    },
    {
      "type": "color",
      "id": "tab_non_active_background_color",
      "label": "Non-Active tab color"
    },
    {
      "type": "color",
      "id": "tab_hover_color",
      "label": "Tab hover color"
    },
    {
      "type": "color",
      "id": "tab_hover_text_color",
      "label": "Tab hover color"
    },
    {
      "type": "color",
      "id": "tab_heading",
      "label": "Tab heading color"
    },
    {
      "type": "color",
      "id": "accordion_icon_color",
      "label": "Icon color"
    },
    {
      "type": "color",
      "id": "accordion_inner_background",
      "label": "Content background"
    },
    {
      "type": "header",
      "content": "Advanced"
    },
    {
      "type": "text",
      "id": "css_class",
      "label": "CSS Class"
    }
  ],
  "blocks": [
      {
        "name": "Heading",
        "type": "heading",
        "settings": [
          {
            "type": "text",
            "id": "title",  
            "label": "Heading",
            "default": "Section heading"
          }
        ]
      },
      {
        "name": "FAQ",
        "type": "faq",
        "settings": [
          {
            "type": "header",
            "content": "FAQ (Structured Data Compatible)"
          },
          {
            "type": "text",
            "id": "custom_id",
            "label": "Custom ID",
            "info": "(Optional) Add a custom html ID for this accordion element that may be used to navigate to and open the accordion from elsewhere on page."
          },
          {
            "type": "text",
            "id": "title",
            "label": "Question",
            "default": "What is your question?"
          },
          {
            "type": "richtext",
            "id": "answer",
            "label": "Answer",
            "default": "<p>Provide the answer to the question here.</p>"
          }
        ]
      },   
  {
      "name": "Custom content",
      "type": "content",
      "settings": [
        {
          "type": "header",
          "content" : "Heading"
        },
        {
        "type": "text",
        "id": "custom_id",
        "label": "Custom ID",
        "info" : "(Optional) Add a custom html ID for this accordion element that may be used to navigate to and open the accordion from elsewhere on page."
      },
    {
      "type": "text",
      "id": "icon_label",
      "label": "Icon",
      "placeholder": "Enter icon name",
      "info": "[Icon list](https://help.outofthesandbox.com/hc/en-us/articles/360021570294)"
    },
        {
          "type": "richtext",
          "id": "title",
          "label": "Accordion Item Heading",
          "default": "<p>Accordion Item Heading</p>"
        },
        {
          "type": "header",
          "content" : "Content"
        },
        {
          "type": "richtext",
          "id": "content_heading",
          "label": "Content Heading",
          "default": "<p>Content heading</p>"
        },
        {
          "type": "image_picker",
          "id": "image_1",
          "label": "Image"
        },
        {
          "type": "range",
          "id": "image_max_width",
          "label": "Image max width",
          "min": 200,
          "max": 1600,
          "step": 25,
          "default":1600,
          "unit": "px"
        },
        {
            "type": "select",
            "id": "image_alignment",
            "label": "Image alignment",
            "default": "left",
            "options": [
              {
                "value": "left",
                "label": "Left"
              },
              {
                "value": "center",
                "label": "Center"
              }
